rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // helper to identify an admin user via custom claim
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // reviews: any logged‑in user can read the full set (dashboard counts, review list);
    // only admins may change status or delete.
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // enquiries: authenticated users can read all enquiries to populate the panel,
    // creation open to public; modification/deletion restricted to admins.
    match /enquiries/{enqId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // bookings: same pattern as enquiries
    match /bookings/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // newsletter: subscribed users may be read by admins only (for export),
    // but on panel everyone is expected to be an admin so allow read for auth
    match /newsletter/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow delete: if isAdmin();
    }

    // gallery images
    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // blog posts
    match /posts/{id} {
      allow read: if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // contact info/settings
    match /contact_info/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // analytics: everyone can log; any signed‑in panel user may read stats
    match /analytics/{docId} {
      allow write: if true;
      allow read: if request.auth != null;
    }

    // lock everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}